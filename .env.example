# ─── Bot Discord ───────────────────────────────────────────────────────────────
# Token du bot (Discord Developer Portal > Bot > Token)
DISCORD_TOKEN=your_discord_bot_token_here

# ─── Supabase ──────────────────────────────────────────────────────────────────
# URL du projet Supabase (Settings > API > Project URL)
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Clé SERVICE ROLE (Settings > API > service_role) — JAMAIS exposée côté client
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Salons Discord ────────────────────────────────────────────────────────────
# Clic droit sur le salon > Copier l'identifiant (Mode développeur doit être activé)
CHANNEL_RESULTS_ID=123456789012345678
CHANNEL_TESTIMONIALS_ID=123456789012345679
